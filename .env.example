# ===========================================
# InterView AI — 环境变量参考（可选覆盖）
# 复制此文件为 .env 或直接在系统环境变量
# 或 docker-compose.yml 中设置
# ===========================================

# JWT 签名密钥（至少 32 字符）
# JWT_SECRET=MyJWTSecretKeyThatIsAtLeast32CharactersLong!!

# API Key AES 加密密钥
# ENCRYPTION_KEY=InterviewAISecret2024

# MySQL 数据库密码
# DB_PASSWORD=123456

# pgvector 数据库密码
# PG_PASSWORD=vector_pass
