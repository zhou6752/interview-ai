<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- 控制台输出：开发时看日志用 -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- 文件输出：生产时查日志用 -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/interview-ai.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- 每天生成一个日志文件 -->
            <fileNamePattern>logs/interview-ai.%d{yyyy-MM-dd}.log</fileNamePattern>
            <!-- 保留 30 天 -->
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- ======================================== -->
    <!-- 日志级别说明: ERROR > WARN > INFO > DEBUG -->
    <!-- ======================================== -->

    <!-- 关掉 Redis/Lettuce 的详细连接日志 -->
    <logger name="org.springframework.data.redis" level="WARN"/>
    <logger name="io.lettuce" level="WARN"/>

    <!-- 关掉 Hibernate 的 SQL 绑定参数日志 -->
    <logger name="org.hibernate" level="WARN"/>

    <!-- 关掉 Spring 框架的自动配置报告 -->
    <logger name="org.springframework" level="WARN"/>

    <!-- 我们自己的代码：打印 DEBUG 及以上（方便调试） -->
    <logger name="com.interviewai" level="DEBUG"/>

    <!-- 开发环境 -->
    <springProfile name="dev">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <!-- 生产环境：控制台 + 文件，只记录 INFO 及以上 -->
    <springProfile name="prod">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
        </root>
    </springProfile>

    <!-- 默认环境：同开发环境 -->
    <springProfile name="!dev,!prod">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

</configuration>
